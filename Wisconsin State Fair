import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.println("Enter the total salary paid");
        double salary = sc.nextDouble();

        int weekendHours = (int)((salary - 800) / 130);
        int weekdayHours = weekendHours + 10;

        System.out.println("Number of weekday hours is " + weekdayHours);
        System.out.println("Number of weekend hours is " + weekendHours);

        sc.close();
    }
}
