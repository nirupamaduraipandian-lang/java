import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int A = sc.nextInt();
        int B = sc.nextInt();

        int minimum = Math.max(A, B);
        int maximum = A + B;

        System.out.println(minimum + " " + maximum);

        sc.close();
    }
}
