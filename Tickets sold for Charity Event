import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.println("Enter the value of X");
        int x = sc.nextInt();

        System.out.println("Enter the value of Y");
        int y = sc.nextInt();

        int children = (y - (5 * x)) / 13;
        int adults = children + x;
        int seniors = 2 * children;

        System.out.println("Number of children tickets sold : " + children);
        System.out.println("Number of adult tickets sold : " + adults);
        System.out.println("Number of senior tickets sold : " + seniors);

        sc.close();
    }
}
