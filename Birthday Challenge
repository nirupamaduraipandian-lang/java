import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.println("Enter m");
        int m = sc.nextInt();

        System.out.println("Enter n");
        int n = sc.nextInt();

        int breaks = (m * n) - 1;

        System.out.println("Minimum number of times is " + breaks);

        sc.close();
    }
}
