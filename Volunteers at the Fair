import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int N = sc.nextInt();
        int M = sc.nextInt();
        int K = sc.nextInt();

        int minDiff = Integer.MAX_VALUE;

        for (int x = 0; x <= K; x++) {
            int firstCollege = N + x;
            int secondCollege = M + (K - x);
            int diff = Math.abs(firstCollege - secondCollege);

            if (diff < minDiff) {
                minDiff = diff;
            }
        }

        System.out.println(minDiff);

        sc.close();
    }
}
